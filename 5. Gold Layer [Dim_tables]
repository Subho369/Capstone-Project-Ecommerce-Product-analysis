--3 join [customers] and [country_state_map] based on the [m.country = c.country and m.state_code=c.state]

%sql
create or replace view ecommerce.gold.gld_customers
as
select customer_id,country_code,
coalesce(c.country,'not_available') as country,
coalesce(state_code) as state_code ,
coalesce(region,'not_available') as regions,
coalesce(phone,'not_available') as phone
from ecommerce.silver.slv_customers as c
left join  ecommerce.silver.slv_country_state_map as m on m.country = c.country and m.state_code=c.state


