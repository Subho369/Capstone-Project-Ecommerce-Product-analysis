
-- 1. Combine dim_tables [slv_products, slv_brand_code, slv_category]

%sql

create or replace view ecommerce.gold.gld_products
as
select 
product_id,
sku,
p.category_code,
lower(c.category_name) as category_name,
p.brand_code,
brand_name,
color,
size,
material,
weight_grams,
length_cm,
width_cm,
height_cm,
rating_clean

from ecommerce.silver.slv_products as p
left join ecommerce.silver.slv_brand_code as b on b.brand_code = p.brand_code
left join ecommerce.silver.slv_category as c on c.category_code = upper(p.category_code)

;

