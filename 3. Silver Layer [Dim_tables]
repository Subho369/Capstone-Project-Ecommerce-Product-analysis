5. --[slv_products] Table:

%sql
CREATE OR REPLACE TABLE ecommerce.silver.slv_products
USING DELTA
AS
select 
product_id,
sku,
category_code,
brand_code,
color,
size,
material,
weight_grams,
length_cm,
width_cm,
height_cm,
rating_clean
from(
select 
trim(product_id) as product_id,
trim(sku) as sku,
trim(category_code) as category_code,
trim(brand_code) as brand_code,
coalesce(trim(color), 'unknown') as color,
trim(size) as size,

    CASE trim(material)
        WHEN 'Coton'   THEN 'Cotton'
        WHEN 'Ruber'   THEN 'Rubber'
        WHEN 'Alumium' THEN 'Aluminium'  
        ELSE material
    END AS material,

abs(CAST(REGEXP_REPLACE((trim(weight_grams)), '[^0-9]', '') AS INT)) as weight_grams ,
cast(replace(trim(length_cm),',','.' ) as decimal(10,2)) as length_cm,
cast(trim(width_cm) as decimal(4,2)) as width_cm,
cast(trim(height_cm) as decimal(4,2)) as height_cm,

    CASE 
        WHEN TRY_CAST(TRIM(rating_count) AS DECIMAL(3,1)) < 0 THEN 0
        WHEN TRY_CAST(TRIM(rating_count) AS DECIMAL(3,1)) > 5 THEN 5
        ELSE TRY_CAST(TRIM(rating_count) AS DECIMAL(3,1))
    END AS rating_clean,
row_number()over(partition by product_id order by product_id) as rnk

from ecommerce.bronze.brz_products
where trim(product_id) is not null
)A
where rnk = 1
;








