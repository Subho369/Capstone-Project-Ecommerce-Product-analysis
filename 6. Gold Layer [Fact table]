3. Final Denormalised Table for analysis and dashboarding :

%sql
-- denormalised data for dashborading analysis

CREATE OR REPLACE VIEW ecommerce.gold.gld_denormalised_order_items AS
select
o.dates
,order_timestamp
,o.customer_id
,cust_id_integrity_flag
,order_id
,item_seq
,o.product_id
,quantity
,unit_price_currency
,unit_price
,inr_rate
,discount_pct
,tax_amount
,tax_flag
,Total_revenue_INR
,Gross_revenue_INR
,channel
,coupon_code
,sku
,category_code
,category_name
,brand_code
,brand_name
,color
,size
,material
,weight_grams
,length_cm
,width_cm
,height_cm
,rating_clean
,country_code
,country
,state_code
,regions
,phone
,year
,day_name
,quarters
,week_of_year
from ecommerce.gold.gld_order_items as o
left join ecommerce.gold.gld_products as p on p.product_id = o.product_id
left join ecommerce.gold.gld_customers as c on c.customer_id = o.customer_id
left join ecommerce.gold.gld_dates as d on d.dates = o.dates







