2. join [order] and [gld_fx_rates_view] and create view:

%sql
CREATE OR REPLACE VIEW ecommerce.gold.gld_order_items AS

select 
order_id,dates,order_timestamp,
customer_id,cust_id_integrity_flag,
item_seq,product_id,
quantity,unit_price_currency,unit_price,inr_rate,discount_pct,tax_amount,tax_flag,
quantity*unit_price*inr_rate*(1-discount_pct) as Total_revenue_INR,
quantity*unit_price*inr_rate as Gross_revenue_INR,
channel,coupon_code
from ecommerce.silver.slv_order_items as o
left join ecommerce.gold.gld_fx_rates_view as m on m.currency = o.unit_price_currency

