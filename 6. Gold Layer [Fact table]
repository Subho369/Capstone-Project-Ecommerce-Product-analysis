-- here i create a mapping table view for currency column so that i can easily connect with the fact_table and do comparison in the inr rates.

-- Create a view for fixed FX rates as of 2025-10-15 as per RBI rates

CREATE OR REPLACE VIEW ecommerce.gold.gld_fx_rates_view AS
SELECT currency, inr_rate, effective_date
FROM VALUES
  ('INR', 1.00, DATE '2025-10-15'),
  ('AED', 24.18, DATE '2025-10-15'),
  ('AUD', 57.55, DATE '2025-10-15'),
  ('CAD', 62.93, DATE '2025-10-15'),
  ('GBP', 117.98, DATE '2025-10-15'),
  ('SGD', 68.18, DATE '2025-10-15'),
  ('USD', 88.29, DATE '2025-10-15')
AS fx_rates(currency, inr_rate, effective_date);

